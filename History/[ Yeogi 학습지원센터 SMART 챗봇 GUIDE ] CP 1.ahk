;------------------------------------------------------------------------------------------
; [ 보완된 SearchAction : 링크 출력 및 파일명 박제 로직 ]
;------------------------------------------------------------------------------------------
SearchAction:
Gui, Submit, NoHide
if (Trim(SearchInput) = "")
    Return

FoundLine := MemorySearch(SearchInput)

if (FoundLine != "") {
    Parts := StrSplit(FoundLine, "|")
    RawAnswer := Parts[3]
    
    ; 1. DB의 4, 5번 열(링크/파일명) 우선 확보
    LastTargetURL := (Parts[4] != "") ? Parts[4] : ""
    LastFileName := (Parts[5] != "") ? Parts[5] : "" ; 일단 비워둠 (아래에서 추출)
    
    FinalAnswer := StrReplace(RawAnswer, "rnrn", "`r`n`r`n")
    if (SubStr(FinalAnswer, 1, 1) = "[") && (SubStr(FinalAnswer, 0) = "]")
        FinalAnswer := SubStr(FinalAnswer, 2, StrLen(FinalAnswer)-2)
    
    GuiControl,, ResultOutput, %FinalAnswer%
    
    ; 2. [핵심 보완] 답변 텍스트에서 모든 링크를 찾아 하단 링크 영역에 표시
    LinkList := []
    Pos := 1
    While (Pos := RegExMatch(FinalAnswer, "https?://[\w\-\./?=&]+", FoundURL, Pos + StrLen(FoundURL))) {
        LinkList.Push(FoundURL)
    }
    
    ; 전역 변수 업데이트 (첫 번째 링크를 우선 타겟으로 설정)
    if (LastTargetURL = "" && LinkList.Length() > 0)
        LastTargetURL := LinkList[1]
    
    ; [파일명 추출] 5번 열이 비어있으면 URL에서 파일명을 유추 (캡처 2번의 파일명 대응)
    if (LastFileName = "" && LastTargetURL != "") {
        ; URL의 마지막 슬래시 뒤를 파일명으로 가져옴
        LastFileName := RegExReplace(LastTargetURL, ".*/")
        ; 만약 확장자가 없거나 너무 짧으면 기본값 부여
        if !InStr(LastFileName, ".")
            LastFileName := "여기스터디_첨부파일.pdf"
    }

    ; UI 업데이트: 캡처 1번에 나온 "핵심 및 관련 링크" 영역에 표시
    Icon := "☞"
    GuiControl,, LinkCore, % (LinkList[1] != "" ? "<a href=""" LinkList[1] """>" Icon " [ 핵심 ] 매뉴얼 : " LinkList[1] "</a>" : "")
    GuiControl,, LinkSub, % (LinkList[2] != "" ? "<a href=""" LinkList[2] """>" Icon " [ 관련 ] 추가파일 : " LinkList[2] "</a>" : "")
}
Return


