Return

;------------------------------------------------------------------------------------------
; [ ZERO CLAW 심장 : 함수형 검색 엔진 ] - 가장 안정적인 메모리 파싱
;------------------------------------------------------------------------------------------
MemorySearch(Input) {
    Global DB_Data
    
    ; 입력값에서 공백을 제거하여 매칭률 향상
    StringReplace, CleanInput, Input, %A_Space%,, All
    
    ; 102개의 DB_Data를 한 줄씩 분석
    Loop, Parse, DB_Data, `n, `r
    {
        if (A_LoopField = "")
            Continue
            
        CurrentLine := A_LoopField
        CurrentParts := StrSplit(CurrentLine, "|")
        if (CurrentParts.MaxIndex() < 3)
            Continue

        Keywords := CurrentParts[2]
        
        ; 키워드 뭉치 안에서 입력값이 있는지 체크
        Loop, Parse, Keywords, `,
        {
            TrimKey := Trim(A_LoopField)
            if (TrimKey != "" && InStr(CleanInput, TrimKey)) {
                ; 매칭되는 즉시 줄 전체 데이터를 반환하며 함수 종료 (모든 루프 자동 탈출)
                Return CurrentLine
            }
        }
    }
    Return "" ; 끝까지 못 찾으면 빈 값 반환
}

