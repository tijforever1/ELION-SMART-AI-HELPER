; 1. 제목 및 파일 번호 분리 (금고 활용)
RegExMatch(g_FullAnswer, "#\s*(.*?)\s*#", MatchRealTitle)
TitleList := StrSplit(Trim(MatchRealTitle1), ";")
FileNumList := StrSplit(g_FileCount, ";")

; 2. 폴더 경로 설정 (역슬래시 무결성 확보)
