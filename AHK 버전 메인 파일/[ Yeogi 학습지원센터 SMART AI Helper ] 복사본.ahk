;------------------------------------------------------------------------------------------
; [ 핵심 : SearchAction 라벨 ] - 함수를 호출하여 문법 오류 원천 차단
;------------------------------------------------------------------------------------------
SearchAction:
Gui, Submit, NoHide
if (Trim(SearchInput) = "")
    Return

; [ ZERO CLAW ] 함수형 엔진으로 검색 (Break 문법 없이 Return으로 즉시 종료)
FoundLine := MemorySearch(SearchInput)

if (FoundLine != "") {
    ; 데이터 분리: [ID] | [Keywords] | [Answer]
    Parts := StrSplit(FoundLine, "|")
	
	; [핵심 추가] 이 세 줄이 있어야 버튼(BtnManual)이 검색 결과를 기억합니당!
    Global g_TargetNum := Parts[4]
    Global g_FileCount := Parts[5]
    Global g_FullAnswer := Parts[3] ; 샵(#) 제목 추출을 위해 원본 답변을 금고에 보관!
	
    RawAnswer := Parts[3]
    
    ; rnrn을 실제 줄바꿈(`r`n)으로 변환
    FinalAnswer := StrReplace(RawAnswer, "rnrn", "`r`n`r`n")
    
    ; 양쪽 대괄호 [] 제거
if (SubStr(FinalAnswer, 1, 1) = "[") && (SubStr(FinalAnswer, 0) = "]")
        FinalAnswer := SubStr(FinalAnswer, 2, StrLen(FinalAnswer)-2)

    ; [아이디어 2번] 출력 전, 샵(#) 기호와 그 사이 내용을 지워서 은닉합니당! <<<< 여기 추가
    DisplayAnswer := RegExReplace(FinalAnswer, "#\s*.*?\s*#", "")

    ; [수정] 원본(FinalAnswer) 대신 숨겨진 버전(DisplayAnswer)을 출력합니당!
    GuiControl,, ResultOutput, %DisplayAnswer%
    
    ; [ 스마트 링크 추출 ]
    Link1 := "", Link2 := ""
    RegExMatch(FinalAnswer, "https?://[\w\-\./?=&]+", Link1)
    RegExMatch(FinalAnswer, "https?://[\w\-\./?=&]+", Link2, StrLen(Link1) + InStr(FinalAnswer, Link1))
    
    ; 하단 링크 버튼 업데이트
    Icon := "☞" 
    GuiControl,, LinkCore, % (Link1 != "" ? "<a href=""" Link1 """>" Icon " [ 핵심 ] 매뉴얼 바로가기 : " Link1 "</a>" : "")
    GuiControl,, LinkSub, % (Link2 != "" ? "<a href=""" Link2 """>" Icon " [ 관련 ] 추가 정보 링크 : " Link2 "</a>" : "")

    GuiControl, MoveDraw, LinkCore
    GuiControl, MoveDraw, LinkSub
} else {
    GuiControl,, ResultOutput, '%SearchInput%'에 대한 내용을 찾을 수 없습니다.
    GuiControl,, LinkCore, 
    GuiControl,, LinkSub, 
}
Return

LinkClick:
Return

;------------------------------------------------------------------------------------------
; [ ZERO CLAW 심장 : 함수형 검색 엔진 ] - 가장 안정적인 메모리 파싱
;------------------------------------------------------------------------------------------
MemorySearch(Input) {
    Global DB_Data
    
    ; 1. [수정] 사용자가 입력한 값에서 모든 공백을 제거합니당!
    StringReplace, CleanInput, Input, %A_Space%,, All
    
    Loop, Parse, DB_Data, `n, `r
    {
        if (A_LoopField = "")
            Continue
            
        CurrentLine := A_LoopField
        CurrentParts := StrSplit(CurrentLine, "|")
        if (CurrentParts.MaxIndex() < 3)
            Continue

        Keywords := CurrentParts[2]
        
        Loop, Parse, Keywords, `,
        {
            ; 2. [수정] DB에 저장된 각 키워드에서도 공백을 제거하고 비교합니당!
            TrimKey := StrReplace(A_LoopField, " ", "") ; 쉼표 앞뒤 공백 제거 및 중간 공백 제거
            
            ; [ 보완 로직 ] : 입력값이 키워드에 포함되거나, 키워드가 입력값에 포함되거나!
			if (TrimKey != "" && (InStr(CleanInput, TrimKey) || InStr(TrimKey, CleanInput))) 
		{
				Return CurrentLine
		}
        }
    }
    Return ""
}


