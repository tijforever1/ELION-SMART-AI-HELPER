if !FileExist(ManualDir)
    FileCreateDir, %ManualDir%

; 3. 다운로드 루프 (URL 직접 결합으로 안전성 확보)
Loop, % FileNumList.MaxIndex()
{
    ; [보완] 파일 번호에서 공백을 완전히 제거합니당!
    CurrentNum := StrReplace(FileNumList[A_Index], " ", "")
    CurrentTitle := Trim(TitleList[A_Index])
    
    If (CurrentTitle = "")
        CurrentTitle := g_TargetNum . "_" . A_Index
    
    CleanName := RegExReplace(CurrentTitle, "[\\/:*?""<>|]", "")
    SavePath := ManualDir . "\Yeogi_" . CleanName . ".pdf"
    
    ; [무결성 URL] 공백 없는 CurrentNum을 사용합니당!
    FullURL := "https://www.yeogicyber.co.kr/web/board/pro/board/filedown.asp?sub_menu_id=9909010300&board_id=faq&group_name=main&down_num=" . g_TargetNum . "&file=" . CurrentNum
    
    UrlDownloadToFile, %FullURL%, %SavePath%
}
